# Slack credentials --------------------------------------------------------
# Bot User OAuth token (Settings → Install App). Starts with xoxb-
SLACK_BOT_TOKEN=xoxb-your-bot-token
# App-level token with connections:write (Settings → Basic Information).
# Required for Socket Mode. Starts with xapp-
SLACK_APP_TOKEN=xapp-your-app-token
# Signing secret (Settings → Basic Information → App Credentials)
SLACK_SIGNING_SECRET=your-signing-secret

# Model providers ----------------------------------------------------------
# Primary model — Claude Sonnet 4.6
ANTHROPIC_API_KEY=sk-ant-your-key
# Fallback model — Gemini 2.5 Flash
GEMINI_API_KEY=your-gemini-key

# Sentinel Shield (RBAC) ----------------------------------------------------
# Comma-separated Slack user IDs who can approve write operations,
# resolve tickets, and create tickets (e.g. U0123ABCD,U0456EFGH)
ADMIN_USERS=

# Proactive incident monitor (optional) -------------------------------------
# Set to 1 to enable the autonomous cascade incident detector
INCIDENT_MONITOR=0
# Channel the proactive alerts are posted to (bot must be a member)
ALERTS_CHANNEL=#alerts
